int puntos{30};  // Podemos modificar el número de puntos que queremos
                 // imprimir en una gráfica
double extremoIzq{0.0};
double extremoDer{10.0};
double incremento{(extremoDer - extremoIzq)/puntos};
std::vector<double> r(puntos);

// Declaración de Funciones 
std::vector<double> potencialLJArgon(std::vector<double>& , const double& ); 


