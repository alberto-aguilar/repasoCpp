// Implementación de funciones
std::vector<double> potencialLJArgon(std::vector<double>& rVec, const double& deltaR)
{
    double epsilon = 0.997; 
    double sigma = 3.40; 
    double razon;
    double r12;
    double r6;
    std::vector<double> V(rVec.size());
    
    for(size_t i = 0 ; i < rVec.size() ; ++i)
    {
         rVec[i] = (i + 1) * deltaR;
         razon = sigma/rVec[i];
         r12 = pow(razon, 12);
         r6  = pow(razon, 6);
         
         V[i] = 4.0 * epsilon * (r12 - r6);
    };  // for(size_t i = 0 ; i < r.size() ; ++i)
    return V;
}; 

